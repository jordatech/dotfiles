{
  "workbench.colorTheme": "Monokai",
  "editor.autoIndent": true,
  "editor.detectIndentation": true,
  "editor.fontSize": 13,
  "editor.tabSize": 4,
  "editor.formatOnPaste": true,
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.snippetSuggestions": "top",
  "window.zoomLevel": 1,
  "workbench.tree.indent": 20,
  "editor.cursorStyle": "block-outline",
  "editor.cursorBlinking": "smooth",
  "editor.rulers": [
      88
  ],
  "editor.wordWrap": "on",
  "redhat.telemetry.enabled": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "[php]": {
    "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
  },
  "[blade]": {
    "editor.defaultFormatter": "shufo.vscode-blade-formatter",
    "editor.formatOnSave": false,
  },
  "git.autofetch": true,
  "editor.fontFamily": "Cascadia Code, Consolas, 'Courier New', monospace",
  "editor.fontLigatures": true,
  "terminal.integrated.fontFamily": "Cascadia Code, Consolas, 'Courier New', monospace",
  "editor.minimap.enabled": false,
  "editor.minimap.renderCharacters": false,
  "editor.minimap.size": "fill",
  "workbench.editorAssociations": {
    "*.sqlite": "default",
  },
  "git.confirmSync": false,
  "workbench.activityBar.location": "top",
  "tabnine.experimentalAutoImports": true,
  "workbench.iconTheme": "catppuccin-perfect-ayu",
  "material-icon-theme.files.color": "#90a4ae",
  "material-icon-theme.folders.color": "#26a69a",
  "material-icon-theme.folders.theme": "specific",
  "material-icon-theme.saturation": 1,
  "material-icon-theme.hidesExplorerArrows": false,
  "material-icon-theme.activeIconPack": "qwik",
  "material-icon-theme.opacity": 0.75,
  "workbench.startupEditor": "none",
  "editor.renderLineHighlight": "none",
  "editor.matchBrackets": "never",
  "terminal.integrated.lineHeight": 1.2,
  "cSpell.userWords": ["seperated", "unnessary"],
  "git.suggestSmartCommit": false,
  "workbench.statusBar.visible": false,
  "tomcat.javaHome": "/Library/Java/JavaVirtualMachines/jdk-21.jdk/Contents/Home",
  "files.autoSave": "afterDelay",
